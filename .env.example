# ──────────────────────────────────────────────────────────────────────────────
# Control Tower — Environment Variables
# Copy this file to .env and fill in the values for your environment.
# .env is git-ignored. NEVER commit secrets.
# ──────────────────────────────────────────────────────────────────────────────

# ── Spring ────────────────────────────────────────────────────────────────────
SPRING_PROFILES_ACTIVE=dev

# ── Server ────────────────────────────────────────────────────────────────────
SERVER_PORT=8080

# ── Database (PostgreSQL) ─────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=controltower
DB_USERNAME=controltower
DB_PASSWORD=controltower123

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ── JWT ───────────────────────────────────────────────────────────────────────
# Minimum 256 bits (32 chars). Use a strong random value in production.
JWT_SECRET=change-me-to-a-strong-256-bit-secret-key-in-production
JWT_ACCESS_EXPIRATION=900        # seconds (15 min)
JWT_REFRESH_EXPIRATION=604800    # seconds (7 days)

# ── Stripe ────────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# ── CORS ──────────────────────────────────────────────────────────────────────
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# ── Mail ──────────────────────────────────────────────────────────────────────
MAIL_HOST=smtp.mailtrap.io
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM=noreply@controltower.io

# ── Encryption ────────────────────────────────────────────────────────────────
ENCRYPTION_KEY=0123456789abcdef0123456789abcdef

# ── Storage ───────────────────────────────────────────────────────────────────
STORAGE_PATH=./uploads

# ── App ───────────────────────────────────────────────────────────────────────
APP_BASE_URL=http://localhost:8080

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
SECURITY_LOG_LEVEL=WARN
